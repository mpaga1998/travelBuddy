# OpenAI API Key
# Get one from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenAI Model Names
# For planning/structuring - use gpt-4 for better quality
OPENAI_PLANNING_MODEL=gpt-4-turbo
# For fallback/simple generation - can use gpt-3.5-turbo for cost efficiency
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo

# Server Port (default: 3000)
PORT=3000

# Reddit API Credentials
# Get these from: https://reddit.com/prefs/apps
# 1. Create an app with type "script"
# 2. Copy client_id, client_secret, and use your Reddit username/password for refresh token
# You can get a refresh token using: https://github.com/not-an-aardvark/reddit-oauth-helper
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_REFRESH_TOKEN=your_refresh_token_here
REDDIT_USER_AGENT=backpack-map-demo/1.0
