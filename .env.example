# ============================================================
# Supabase
# ============================================================
# Public: exposed to the browser via Vite.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ... # safe to ship to the client

# Server-only: NEVER prefix with VITE_. The service-role key bypasses RLS,
# so it must never end up in the browser bundle. Only referenced from api/.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# OpenAI
# ============================================================
# Get one from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# For planning/structuring - use gpt-4 for better quality
OPENAI_PLANNING_MODEL=gpt-4-turbo
# For fallback/simple generation - can use gpt-3.5-turbo for cost efficiency
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo

# ============================================================
# Mapbox (client)
# ============================================================
VITE_MAPBOX_TOKEN=pk.ey...

# ============================================================
# Optional
# ============================================================
# Override the API base the frontend talks to. Leave unset in prod - the
# frontend uses a relative /api path by default.
# VITE_API_BASE_URL=https://your-preview.example.com/api
